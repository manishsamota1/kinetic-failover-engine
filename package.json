{
  "name": "kinetic-failover-engine",
  "version": "1.0.0",
  "description": "Zero-Downtime Kinetic Failover Engine for enterprise cloud infrastructure. Detects regional latency spikes or outages and automatically reroutes traffic to a mirrored ECS cluster in a secondary AWS region.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js start",
    "dev": "node --watch src/index.js start",
    "dry-run": "node src/index.js dry-run",
    "status": "node src/index.js status",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/unit --forceExit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/integration --forceExit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "chaos": "node tests/chaos/simulateOutage.js"
  },
  "keywords": [
    "failover",
    "aws",
    "ecs",
    "route53",
    "alb",
    "zero-downtime",
    "disaster-recovery",
    "multi-region",
    "cloud-infrastructure"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.700.0",
    "@aws-sdk/client-route-53": "^3.700.0",
    "@aws-sdk/client-sns": "^3.700.0",
    "ajv": "^8.17.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "nock": "^14.0.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
