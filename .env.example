# ============================================================
# Zero-Downtime Kinetic Failover Engine — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# These override settings in config/default.yaml.
# ============================================================

# --- AWS Credentials ---
# Use IAM roles in production instead of hardcoding keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Region Configuration ---
AWS_REGION_PRIMARY=us-east-1
AWS_REGION_SECONDARY=eu-west-1

# --- Route 53 ---
ROUTE53_HOSTED_ZONE_ID=
ROUTE53_DOMAIN_NAME=

# --- ECS (Primary) ---
ECS_CLUSTER_PRIMARY=
ECS_SERVICE_PRIMARY=
ECS_TASK_DEFINITION_PRIMARY=

# --- ECS (Secondary) ---
ECS_CLUSTER_SECONDARY=
ECS_SERVICE_SECONDARY=
ECS_TASK_DEFINITION_SECONDARY=

# --- ALB (Primary) ---
ALB_ARN_PRIMARY=
ALB_DNS_PRIMARY=
ALB_TARGET_GROUP_ARN_PRIMARY=

# --- ALB (Secondary) ---
ALB_ARN_SECONDARY=
ALB_DNS_SECONDARY=
ALB_TARGET_GROUP_ARN_SECONDARY=

# --- DynamoDB (Split-Brain Lock) ---
DYNAMODB_LOCK_TABLE=kinetic-failover-locks

# --- Alerting: SNS ---
SNS_TOPIC_ARN=

# --- Alerting: Slack ---
SLACK_WEBHOOK_URL=

# --- Alerting: PagerDuty ---
PAGERDUTY_ROUTING_KEY=

# --- Engine Tuning ---
# HEALTH_CHECK_INTERVAL_MS=5000
# LATENCY_THRESHOLD_MS=200
# FAILURE_THRESHOLD=3
# COOLDOWN_PERIOD_MS=60000
# DNS_TTL=30

# --- Logging ---
# LOG_LEVEL=info
