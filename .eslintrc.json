{
  "env": {
    "node": true,
    "es2024": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error",
    "no-throw-literal": "error",
    "no-return-await": "warn",
    "no-async-promise-executor": "error",
    "require-await": "warn",
    "curly": "error",
    "no-implicit-coercion": "error",
    "no-duplicate-imports": "error"
  }
}
